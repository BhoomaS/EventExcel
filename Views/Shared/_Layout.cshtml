<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Member Summary Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        .logout-btn {
            position: absolute;
            right: 20px;
            top: 20px;
            z-index: 99;
            background-color: #ced4da;
            color: #000;
            left: auto;
            width: auto;
        }

        .download-btn {
            position: absolute;
            right: 20px;
            top: 100px;
            z-index: 99;
            background-color: #ced4da;
            color: #000;
            left: auto;
            width: auto;
        }
        .logout-btn:hover {
                color: #fff; 
         }

        .download-btn:hover {
            color: #fff;
        }
        .loader-fixed{
            position:fixed;
            left:0;
            top:0;
            z-index:999;
            pointer-events:none;
            background-color:rgba(0,0,0,0.5);
            width:100%;
            height:100%;
        }
    </style>
</head>
<body>
    <header>
        <div class="container-fluid">
            <button class="logout-btn" id="logoutBtn">Logout</button>
        </div>
        
        <div class="container-fluid">
            <button class="btn btn-primary download-btn" id="downloadBtn">
                <span id="downloadBtnContent">
                    <i class="bi bi-download"></i> Sample Excel
                </span>
                <div class="class=" loader-fixed">
                    <span id="downloadSpinner" class="spinner-border spinner-border-sm ms-2 d-none" role="status" aria-hidden="true"></span>
                </div>
                
            </button>
        </div>


        <nav class="navbar navbar-expand-sm navbar-toggleable-sm mb-1">
            
            <div class="container">
                <h3 class="header-title">Member Summary Dashboard</h3>
                @* <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Member Summary Dashboard</a> *@
                <button class="navbar-toggler" type="button" data-toggle="collapse" data-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex flex-sm-row-reverse">
                    <ul class="navbar-nav flex-grow-1">
                       @*  <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li> *@
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - MemberSummary Dashboard
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
  

</body>
</html>
